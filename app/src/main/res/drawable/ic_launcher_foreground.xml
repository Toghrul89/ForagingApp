        android:pathData="M54,55 C58,50 64,46 70,42"/>

    <!-- Branch left -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#5D4037"
        android:strokeWidth="2.5"
        android:strokeLineCap="round"
        android:pathData="M54,64 C50,60 44,56 40,52"/>

    <!-- Leaves -->
    <path
        android:fillColor="#4CAF50"
        android:pathData="M42,30 C38,26 32,28 34,34 C36,40 44,38 42,30Z"/>
    <path
        android:fillColor="#388E3C"
        android:pathData="M70,42 C74,38 80,40 78,46 C76,52 68,50 70,42Z"/>
