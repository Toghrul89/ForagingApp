    <circle android:fillColor="#E53935" android:cx="72" android:cy="38" android:r="3"
        android:alpha="0.4"/>
    <!-- Cluster 3 left mid -->
    <circle android:fillColor="#B71C1C" android:cx="36" android:cy="50" android:r="5"/>
    <circle android:fillColor="#E53935" android:cx="36" android:cy="50" android:r="2.5"
        android:alpha="0.35"/>
    <!-- Small berry accent -->
    <circle android:fillColor="#C62828" android:cx="46" android:cy="35" android:r="3.5"/>
    <circle android:fillColor="#C62828" android:cx="63" android:cy="48" android:r="3.5"/>

    <!-- Tiny specular highlight on berries -->
    <circle android:fillColor="#FFFFFF" android:cx="37" android:cy="24.5" android:r="1.5"
        android:alpha="0.5"/>
    <circle android:fillColor="#FFFFFF" android:cx="71" android:cy="36.5" android:r="1.5"
        android:alpha="0.5"/>

