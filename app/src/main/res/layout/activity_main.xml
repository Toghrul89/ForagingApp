<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:paddingBottom="112dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingTop="24dp"
            android:paddingEnd="24dp"
            android:paddingBottom="140dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="360dp"
                android:clipChildren="false">

                <TextView
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:layout_gravity="top|start"
                    android:background="@drawable/home_logo_bg"
                    android:contentDescription="@string/app_name"
                    android:gravity="center"
                    android:text="@string/icon_leaf"
                    android:textColor="@color/textOnDark"
                    android:textSize="30sp"/>

                <TextView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_gravity="top|end"
                    android:contentDescription="@string/notifications"
                    android:gravity="center"
                    android:text="@string/icon_bell"
                    android:textColor="@color/primary"
                    android:textSize="30sp"/>

                <View
                    android:layout_width="230dp"
                    android:layout_height="230dp"
                    android:layout_gravity="top|end"
                    android:layout_marginTop="88dp"
                    android:layout_marginEnd="-56dp"
                    android:alpha="0.7"
                    android:background="@drawable/hero_leaf_glow"/>

                <TextView
                    android:layout_width="230dp"
                    android:layout_height="160dp"
                    android:layout_gravity="top|end"
                    android:layout_marginTop="112dp"
                    android:layout_marginEnd="-18dp"
                    android:gravity="center"
                    android:text="@string/hero_fruit_art"
                    android:textSize="58sp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top"
                    android:layout_marginTop="138dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="260dp"
                        android:layout_height="wrap_content"
                        android:fontFamily="serif"
                        android:lineSpacingMultiplier="1.05"
                        android:text="@string/home_title"
                        android:textColor="@color/primary"
                        android:textSize="42sp"/>

                    <TextView
                        android:layout_width="230dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:lineSpacingMultiplier="1.35"
                        android:text="@string/home_subtitle"
                        android:textColor="@color/textSecondary"
                        android:textSize="17sp"/>
                </LinearLayout>

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardSearchHome"
                    android:layout_width="match_parent"
                    android:layout_height="74dp"
                    android:layout_gravity="bottom"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    app:cardBackgroundColor="@color/surface"
                    app:cardCornerRadius="37dp"
                    app:cardElevation="10dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="26dp"
                        android:paddingEnd="14dp">

                        <TextView
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:gravity="center"
                            android:text="@string/icon_search"
                            android:textColor="@color/primary"
                            android:textSize="30sp"/>

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:paddingStart="16dp"
                            android:text="@string/home_search_hint"
                            android:textColor="@color/textHint"
                            android:textSize="16sp"/>

                        <TextView
                            android:id="@+id/buttonLocateHome"
                            android:layout_width="58dp"
                            android:layout_height="58dp"
                            android:background="@drawable/circle_primary"
                            android:gravity="center"
                            android:text="@string/icon_target"
                            android:textColor="@color/textOnDark"
                            android:textSize="30sp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </FrameLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="112dp"
                android:layout_marginTop="26dp"
                android:orientation="horizontal">

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardViewLogs"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginEnd="9dp"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    app:cardBackgroundColor="@color/surface"
                    app:cardCornerRadius="22dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/icon_berries"
                            android:textColor="@color/leafGreen"
                            android:textSize="34sp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="@string/all_fruits"
                            android:textColor="@color/textPrimary"
                            android:textSize="14sp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardOpenMap"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginStart="9dp"
                    android:layout_marginEnd="9dp"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    app:cardBackgroundColor="@color/surface"
                    app:cardCornerRadius="22dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/icon_pin"
                            android:textColor="@color/primary"
                            android:textSize="34sp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="@string/near_me"
                            android:textColor="@color/textPrimary"
                            android:textSize="14sp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardLogEntry"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginStart="9dp"
                    android:layout_marginEnd="9dp"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    app:cardBackgroundColor="@color/surface"
                    app:cardCornerRadius="22dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/icon_leaf_outline"
                            android:textColor="@color/leafGreen"
                            android:textSize="34sp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="@string/in_season"
                            android:textColor="@color/textPrimary"
                            android:textSize="14sp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardSavedHome"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginStart="9dp"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    app:cardBackgroundColor="@color/surface"
                    app:cardCornerRadius="22dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/icon_bookmark"
                            android:textColor="@color/primary"
                            android:textSize="34sp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="@string/saved"
                            android:textColor="@color/textPrimary"
                            android:textSize="14sp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="34dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="serif"
                        android:text="@string/in_season_now"
                        android:textColor="@color/textPrimary"
                        android:textSize="24sp"/>

                    <TextView
                        android:id="@+id/tvSpotCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="5dp"
                        android:text="@string/zero_trees_spotted"
                        android:textColor="@color/textSecondary"
                        android:textSize="13sp"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tvFavCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingEnd="14dp"
                    android:text="@string/zero_favourites"
                    android:textColor="@color/leafGreen"
                    android:textSize="14sp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/icon_arrow_right"
                    android:textColor="@color/leafGreen"
                    android:textSize="26sp"/>
            </LinearLayout>

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:clipToPadding="false"
                android:overScrollMode="never"
                android:paddingEnd="24dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <include layout="@layout/item_season_fruit_blackberry"/>
                    <include layout="@layout/item_season_fruit_elderberry"/>
                    <include layout="@layout/item_season_fruit_raspberry"/>
                    <include layout="@layout/item_season_fruit_serviceberry"/>
                </LinearLayout>
            </HorizontalScrollView>
        </LinearLayout>
    </ScrollView>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="86dp"
        android:layout_gravity="bottom"
        android:layout_marginStart="22dp"
        android:layout_marginEnd="22dp"
        android:layout_marginBottom="18dp"
        app:cardBackgroundColor="@color/surface"
        app:cardCornerRadius="42dp"
        app:cardElevation="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingEnd="12dp">

            <TextView
                android:id="@+id/navHome"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/nav_home"
                android:textColor="@color/primary"
                android:textSize="12sp"/>

            <TextView
                android:id="@+id/navExplore"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/nav_explore"
                android:textColor="@color/textSecondary"
                android:textSize="12sp"/>

            <TextView
                android:id="@+id/navIdentify"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/circle_primary"
                android:gravity="center"
                android:text="@string/nav_identify"
                android:textColor="@color/textOnDark"
                android:textSize="12sp"/>

            <TextView
                android:id="@+id/navMap"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/nav_map"
                android:textColor="@color/textSecondary"
                android:textSize="12sp"/>

            <TextView
                android:id="@+id/navProfile"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/nav_profile"
                android:textColor="@color/textSecondary"
                android:textSize="12sp"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
