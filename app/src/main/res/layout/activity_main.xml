<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="false"
        android:overScrollMode="ifContentScrolls"
        android:paddingBottom="132dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingTop="28dp"
            android:paddingEnd="24dp"
            android:paddingBottom="24dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="430dp"
                android:clipChildren="false">

                <ImageView
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:layout_gravity="top|start"
                    android:background="@drawable/home_logo_bg"
                    android:contentDescription="@string/app_name"
                    android:padding="16dp"
                    android:src="@drawable/ic_leaf"
                    app:tint="@color/textOnDark"/>

                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_gravity="top|end"
                    android:contentDescription="@string/notifications"
                    android:padding="10dp"
                    android:src="@drawable/ic_bell"
                    app:tint="@color/primary"/>

                <View
                    android:layout_width="230dp"
                    android:layout_height="220dp"
                    android:layout_gravity="top|end"
                    android:layout_marginTop="120dp"
                    android:layout_marginEnd="-60dp"
                    android:alpha="0.65"
                    android:background="@drawable/hero_leaf_glow"/>

                <ImageView
                    android:layout_width="188dp"
                    android:layout_height="150dp"
                    android:layout_gravity="top|end"
                    android:layout_marginTop="150dp"
                    android:layout_marginEnd="-10dp"
                    android:alpha="0.95"
                    android:contentDescription="@string/hero_fruit_illustration"
                    android:padding="20dp"
                    android:src="@drawable/ic_leaf_cluster"
                    app:tint="@color/primaryLight"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top"
                    android:layout_marginTop="136dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="270dp"
                        android:layout_height="wrap_content"
                        android:fontFamily="serif"
                        android:lineSpacingMultiplier="1.05"
                        android:text="@string/home_title"
                        android:textColor="@color/primary"
                        android:textSize="38sp"/>

                    <TextView
                        android:layout_width="236dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:lineSpacingMultiplier="1.35"
                        android:text="@string/home_subtitle"
                        android:textColor="@color/textSecondary"
                        android:textSize="17sp"/>
                </LinearLayout>

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardSearchHome"
                    android:layout_width="match_parent"
                    android:layout_height="74dp"
                    android:layout_gravity="bottom"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    app:cardBackgroundColor="@color/surface"
                    app:cardCornerRadius="37dp"
                    app:cardElevation="8dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="24dp"
                        android:paddingEnd="14dp">

                        <ImageView
                            android:layout_width="38dp"
                            android:layout_height="38dp"
                            android:contentDescription="@string/search"
                            android:padding="5dp"
                            android:src="@drawable/ic_search"
                            app:tint="@color/primary"/>

                        <AutoCompleteTextView
                            android:id="@+id/homeSearchInput"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:background="@android:color/transparent"
                            android:completionThreshold="1"
                            android:hint="@string/home_search_hint"
                            android:imeOptions="actionSearch"
                            android:inputType="text"
                            android:paddingStart="16dp"
                            android:singleLine="true"
                            android:textColor="@color/textPrimary"
                            android:textColorHint="@color/textHint"
                            android:textSize="16sp"/>

                        <ImageButton
                            android:id="@+id/buttonLocateHome"
                            android:layout_width="58dp"
                            android:layout_height="58dp"
                            android:background="@drawable/circle_primary"
                            android:contentDescription="@string/near_me"
                            android:padding="15dp"
                            android:src="@drawable/ic_target"
                            app:tint="@color/textOnDark"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </FrameLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="112dp"
                android:layout_marginTop="26dp"
                android:orientation="horizontal">

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardViewLogs"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    app:cardBackgroundColor="@color/surface"
                    app:cardCornerRadius="22dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical">

                        <ImageView
                            android:layout_width="34dp"
                            android:layout_height="34dp"
                            android:src="@drawable/ic_fruit"
                            app:tint="@color/leafGreen"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:text="@string/all_fruits"
                            android:textColor="@color/textPrimary"
                            android:textSize="14sp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardOpenMap"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    app:cardBackgroundColor="@color/surface"
                    app:cardCornerRadius="22dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical">

                        <ImageView
                            android:layout_width="34dp"
                            android:layout_height="34dp"
                            android:src="@drawable/ic_pin"
                            app:tint="@color/primary"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:text="@string/near_me"
                            android:textColor="@color/textPrimary"
                            android:textSize="14sp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardLogEntry"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    app:cardBackgroundColor="@color/surface"
                    app:cardCornerRadius="22dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical">

                        <ImageView
                            android:layout_width="34dp"
                            android:layout_height="34dp"
                            android:src="@drawable/ic_leaf"
                            app:tint="@color/leafGreen"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:text="@string/add_tree"
                            android:textColor="@color/textPrimary"
                            android:textSize="14sp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardSavedHome"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    app:cardBackgroundColor="@color/surface"
                    app:cardCornerRadius="22dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical">

                        <ImageView
                            android:layout_width="34dp"
                            android:layout_height="34dp"
                            android:src="@drawable/ic_bookmark"
                            app:tint="@color/primary"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:text="@string/saved"
                            android:textColor="@color/textPrimary"
                            android:textSize="14sp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="34dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="serif"
                        android:text="@string/in_season_now"
                        android:textColor="@color/textPrimary"
                        android:textSize="24sp"/>

                    <TextView
                        android:id="@+id/tvSpotCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="5dp"
                        android:text="@string/zero_trees_spotted"
                        android:textColor="@color/textSecondary"
                        android:textSize="13sp"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tvFavCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingEnd="12dp"
                    android:text="@string/zero_favourites"
                    android:textColor="@color/leafGreen"
                    android:textSize="14sp"/>
            </LinearLayout>

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:clipToPadding="false"
                android:overScrollMode="never"
                android:paddingEnd="24dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <include layout="@layout/item_season_fruit_blackberry"/>
                    <include layout="@layout/item_season_fruit_elderberry"/>
                    <include layout="@layout/item_season_fruit_raspberry"/>
                    <include layout="@layout/item_season_fruit_serviceberry"/>
                    <include
                        android:id="@+id/cardSeasonMore"
                        layout="@layout/item_season_more"/>
                </LinearLayout>
            </HorizontalScrollView>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="38dp"
                android:fontFamily="serif"
                android:text="@string/about_title"
                android:textColor="@color/textPrimary"
                android:textSize="24sp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/app_tagline"
                android:textColor="@color/leafGreen"
                android:textSize="13sp"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/row_bg"
                android:lineSpacingMultiplier="1.35"
                android:padding="20dp"
                android:text="@string/about_full_text"
                android:textColor="@color/textSecondary"
                android:textSize="15sp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="8dp"
                android:lineSpacingMultiplier="1.25"
                android:text="@string/terms_summary"
                android:textColor="@color/textHint"
                android:textSize="12sp"/>
        </LinearLayout>
    </ScrollView>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="82dp"
        android:layout_gravity="bottom"
        android:layout_marginStart="22dp"
        android:layout_marginEnd="22dp"
        android:layout_marginBottom="18dp"
        app:cardBackgroundColor="@color/surface"
        app:cardCornerRadius="41dp"
        app:cardElevation="10dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingEnd="12dp">

            <TextView
                android:id="@+id/navHome"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/nav_home"
                android:textColor="@color/primary"
                android:textSize="12sp"/>

            <TextView
                android:id="@+id/navExplore"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/nav_explore"
                android:textColor="@color/textSecondary"
                android:textSize="12sp"/>

            <TextView
                android:id="@+id/navIdentify"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/circle_primary"
                android:gravity="center"
                android:text="@string/nav_identify"
                android:textColor="@color/textOnDark"
                android:textSize="12sp"/>

            <TextView
                android:id="@+id/navMap"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/nav_map"
                android:textColor="@color/textSecondary"
                android:textSize="12sp"/>

            <TextView
                android:id="@+id/navProfile"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/nav_profile"
                android:textColor="@color/textSecondary"
                android:textSize="12sp"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
