<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Hero Header with organic blob shapes -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="280dp">

                <!-- Sage blob top-right -->
                <View
                    android:layout_width="180dp"
                    android:layout_height="180dp"
                    android:layout_gravity="top|end"
                    android:layout_marginTop="-40dp"
                    android:layout_marginEnd="-40dp"
                    android:background="@drawable/blob_sage"
                    android:alpha="0.5"/>

                <!-- Blush blob bottom-left -->
                <View
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:layout_gravity="bottom|start"
                    android:layout_marginStart="20dp"
                    android:layout_marginBottom="-20dp"
                    android:background="@drawable/blob_blush"
                    android:alpha="0.4"/>

                <!-- Text content -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:paddingStart="28dp"
                    android:paddingEnd="28dp"
                    android:paddingTop="52dp"
                    android:paddingBottom="28dp"
                    android:gravity="bottom">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="FORAGE"
                        android:textSize="11sp"
                        android:letterSpacing="0.25"
                        android:textColor="@color/accent"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Your wild\nharvest log."
                        android:textSize="36sp"
                        android:lineSpacingMultiplier="1.05"
                        android:textColor="@color/textPrimary"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Track, map, and revisit every spot."
                        android:textSize="14sp"
                        android:textColor="@color/textSecondary"
                        android:layout_marginTop="10dp"/>

                </LinearLayout>
            </FrameLayout>

            <!-- Action Cards -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp">

                <!-- Add a spot — dark primary card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/primary">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="24dp">

                        <TextView
                            android:id="@+id/labelNewLog"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="NEW LOG"
                            android:textSize="10sp"
                            android:letterSpacing="0.2"
                            android:textColor="#88FFFFFF"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Add a spot"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:textColor="@color/textOnDark"
                            android:layout_below="@id/labelNewLog"
                            android:layout_marginTop="4dp"/>

                        <Button
                            android:id="@+id/btnLogEntry"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            android:text="Start →"
                            android:textColor="@color/textOnDark"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            app:strokeColor="#55FFFFFF"
                            app:cornerRadius="20dp"/>

                    </RelativeLayout>
                </androidx.cardview.widget.CardView>

                <!-- My Logs + Map row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">

                    <!-- My Logs card — sage tint -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="0dp"
                        android:layout_height="130dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        app:cardCornerRadius="24dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="@color/blobSage">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:padding="20dp"
                            android:gravity="bottom">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="My Logs"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:textColor="@color/primary"/>

                            <Button
                                android:id="@+id/btnViewLogs"
                                style="@style/Widget.Material3.Button.TextButton"
                                android:layout_width="wrap_content"
                                android:layout_height="32dp"
                                android:text="View →"
                                android:textColor="@color/accentDark"
                                android:paddingStart="0dp"
                                android:minWidth="0dp"/>

                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- Map card — blush tint -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="0dp"
                        android:layout_height="130dp"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        app:cardCornerRadius="24dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="@color/blobBlush">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:padding="20dp"
                            android:gravity="bottom">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Explore Map"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:textColor="@color/primary"/>

                            <Button
                                android:id="@+id/btnOpenMap"
                                style="@style/Widget.Material3.Button.TextButton"
                                android:layout_width="wrap_content"
                                android:layout_height="32dp"
                                android:text="Open →"
                                android:textColor="@color/accentDark"
                                android:paddingStart="0dp"
                                android:minWidth="0dp"/>

                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                </LinearLayout>
            </LinearLayout>

            <!-- About Section -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:layout_marginTop="12dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="28dp"
                android:paddingEnd="28dp"
                android:paddingTop="28dp"
                android:paddingBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ABOUT"
                    android:textSize="10sp"
                    android:letterSpacing="0.2"
                    android:textColor="@color/textHint"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Built for foragers."
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/textPrimary"
                    android:layout_marginBottom="10dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="This app was built to make it easy to track, log, and revisit foraging spots in the wild. Created as a personal portfolio project by a software development student who loves the outdoors."
                    android:textSize="14sp"
                    android:lineSpacingMultiplier="1.6"
                    android:textColor="@color/textSecondary"/>

            </LinearLayout>

            <!-- Footer -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="28dp"
                android:paddingEnd="28dp"
                android:paddingTop="24dp"
                android:paddingBottom="48dp"
                android:gravity="center_horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="FORAGE APP"
                    android:textSize="11sp"
                    android:letterSpacing="0.2"
                    android:textColor="@color/textPrimary"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Made with care for the wild."
                    android:textSize="12sp"
                    android:textColor="@color/textHint"
                    android:layout_marginTop="4dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="v1.0  ·  Seattle, WA"
                    android:textSize="11sp"
                    android:textColor="@color/textHint"
                    android:layout_marginTop="4dp"/>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>