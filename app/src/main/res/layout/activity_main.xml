<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Hero with blobs -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="260dp"
                android:clipChildren="false">

                <View
                    android:layout_width="220dp"
                    android:layout_height="220dp"
                    android:layout_gravity="top|end"
                    android:layout_marginTop="-50dp"
                    android:layout_marginEnd="-60dp"
                    android:background="@drawable/blob_sage"
                    android:alpha="0.55"/>

                <View
                    android:layout_width="140dp"
                    android:layout_height="140dp"
                    android:layout_gravity="bottom|start"
                    android:layout_marginStart="20dp"
                    android:layout_marginBottom="-30dp"
                    android:background="@drawable/blob_blush"
                    android:alpha="0.5"/>

                <View
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:layout_gravity="top|start"
                    android:layout_marginStart="-20dp"
                    android:layout_marginTop="60dp"
                    android:background="@drawable/blob_blush"
                    android:alpha="0.3"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:paddingStart="28dp"
                    android:paddingEnd="28dp"
                    android:paddingTop="56dp"
                    android:gravity="top">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="FORAGE"
                        android:textSize="10sp"
                        android:letterSpacing="0.3"
                        android:textColor="@color/accent"
                        android:layout_marginBottom="10dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Your wild\nharvest log."
                        android:textSize="36sp"
                        android:lineSpacingMultiplier="1.05"
                        android:textColor="@color/textPrimary"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Track, map &amp; revisit every spot."
                        android:textSize="14sp"
                        android:textColor="@color/textSecondary"
                        android:layout_marginTop="10dp"/>

                </LinearLayout>
            </FrameLayout>

            <!-- Action Cards -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="12dp"
                android:paddingBottom="8dp">

                <!-- Add Spot dark card -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/btnLogEntry"
                    android:layout_width="match_parent"
                    android:layout_height="88dp"
                    android:layout_marginBottom="12dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardCornerRadius="22dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/primary">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:paddingStart="24dp"
                        android:paddingEnd="20dp">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="NEW LOG"
                                android:textSize="10sp"
                                android:letterSpacing="0.15"
                                android:textColor="#77FFFFFF"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Add a new spot"
                                android:textSize="19sp"
                                android:textStyle="bold"
                                android:textColor="#FFFFFF"/>
                        </LinearLayout>

                        <androidx.cardview.widget.CardView
                            android:layout_width="80dp"
                            android:layout_height="38dp"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            app:cardCornerRadius="19dp"
                            app:cardElevation="0dp"
                            app:cardBackgroundColor="#44FFFFFF">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:text="Start →"
                                android:textSize="12sp"
                                android:textColor="#FFFFFF"
                                android:gravity="center"/>

                        </androidx.cardview.widget.CardView>

                    </RelativeLayout>
                </androidx.cardview.widget.CardView>

                <!-- My Logs + Map row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="140dp"
                    android:orientation="horizontal"
                    android:layout_marginBottom="4dp">

                    <androidx.cardview.widget.CardView
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:clickable="true"
                        android:focusable="true"
                        app:cardCornerRadius="22dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="@color/blobSage">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:padding="20dp"
                            android:gravity="bottom">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="My Forage Log"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="@color/primary"/>

                            <Button
                                android:id="@+id/btnViewLogs"
                                style="@style/Widget.Material3.Button.TextButton"
                                android:layout_width="wrap_content"
                                android:layout_height="30dp"
                                android:text="View →"
                                android:textColor="@color/accentDark"
                                android:textSize="12sp"
                                android:paddingStart="0dp"
                                android:minWidth="0dp"/>

                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <androidx.cardview.widget.CardView
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:clickable="true"
                        android:focusable="true"
                        app:cardCornerRadius="22dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="@color/blobBlush">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:padding="20dp"
                            android:gravity="bottom">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Explore Map"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="@color/primary"/>

                            <Button
                                android:id="@+id/btnOpenMap"
                                style="@style/Widget.Material3.Button.TextButton"
                                android:layout_width="wrap_content"
                                android:layout_height="30dp"
                                android:text="Open →"
                                android:textColor="@color/accentDark"
                                android:textSize="12sp"
                                android:paddingStart="0dp"
                                android:minWidth="0dp"/>

                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                </LinearLayout>
            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:layout_marginTop="16dp"/>

            <!-- About -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="28dp"
                android:paddingEnd="28dp"
                android:paddingTop="28dp"
                android:paddingBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ABOUT"
                    android:textSize="10sp"
                    android:letterSpacing="0.2"
                    android:textColor="@color/textHint"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Built for foragers."
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="@color/textPrimary"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="This app was built to make it easy to track, log, and revisit foraging spots in the wild. Created as a personal portfolio project by a software development student who loves the outdoors."
                    android:textSize="14sp"
                    android:lineSpacingMultiplier="1.7"
                    android:textColor="@color/textSecondary"/>

            </LinearLayout>

            <!-- Footer -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="24dp"
                android:paddingBottom="52dp"
                android:gravity="center_horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="FORAGE APP"
                    android:textSize="11sp"
                    android:letterSpacing="0.2"
                    android:textColor="@color/textPrimary"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Made with care for the wild."
                    android:textSize="12sp"
                    android:textColor="@color/textHint"
                    android:layout_marginTop="4dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="v1.0  ·  Seattle, WA"
                    android:textSize="11sp"
                    android:textColor="@color/textHint"
                    android:layout_marginTop="4dp"/>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>