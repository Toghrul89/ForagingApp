<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/background"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/background"
            app:title="Tree Details"
            app:titleTextColor="@color/textPrimary"/>
    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingStart="22dp"
        android:paddingTop="12dp"
        android:paddingEnd="22dp"
        android:paddingBottom="24dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/imageTree"
                android:layout_width="match_parent"
                android:layout_height="210dp"
                android:background="@drawable/row_bg"
                android:contentDescription="Tree image"
                android:scaleType="centerCrop"
                android:visibility="gone"/>

            <TextView
                android:id="@+id/textName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:fontFamily="serif"
                android:textColor="@color/textPrimary"
                android:textSize="30sp"/>

            <TextView
                android:id="@+id/textMeta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="@color/textSecondary"
                android:textSize="14sp"/>

            <TextView
                android:id="@+id/textNotes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:background="@drawable/row_bg"
                android:lineSpacingMultiplier="1.35"
                android:padding="16dp"
                android:textColor="@color/textPrimary"
                android:textSize="15sp"/>

            <TextView
                android:id="@+id/textTrust"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/tag_bg_green"
                android:padding="12dp"
                android:textColor="@color/leafGreen"
                android:textSize="13sp"/>

            <Button
                android:id="@+id/buttonWikipedia"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="18dp"
                android:backgroundTint="@color/primary"
                android:text="Learn More on Wikipedia"
                android:textColor="@color/textOnDark"
                app:cornerRadius="18dp"/>

            <TextView
                android:id="@+id/textSafety"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/row_bg"
                android:padding="14dp"
                android:text="Do not consume plants or fruits unless properly identified."
                android:textColor="@color/textSecondary"
                android:textSize="13sp"/>

            <Button
                android:id="@+id/buttonEdit"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="12dp"
                android:text="Edit Tree"
                android:textColor="@color/leafGreen"
                app:cornerRadius="18dp"
                app:strokeColor="@color/leafGreen"/>

            <Button
                android:id="@+id/buttonReport"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="10dp"
                android:text="Report Issue"
                android:textColor="@color/textSecondary"
                app:cornerRadius="18dp"
                app:strokeColor="@color/border"/>

            <Button
                android:id="@+id/buttonDelete"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="10dp"
                android:text="Delete Tree"
                android:textColor="@color/error"
                app:cornerRadius="18dp"
                app:strokeColor="@color/error"/>
        </LinearLayout>
    </ScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
