<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@color/surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="14dp"
        android:gravity="center_vertical">

        <!-- Square thumbnail — always visible -->
        <ImageView
            android:id="@+id/ivLogThumbnail"
            android:layout_width="68dp"
            android:layout_height="68dp"
            android:scaleType="centerCrop"
            android:background="@drawable/rounded_image"
            android:contentDescription="Spot photo"
            android:layout_marginEnd="14dp"
            android:clipToOutline="true"/>

        <!-- Text -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvLogName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/textPrimary"
                android:layout_marginBottom="2dp"/>

            <TextView
                android:id="@+id/tvLogDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="@color/textHint"
                android:layout_marginBottom="3dp"/>

            <TextView
                android:id="@+id/tvLogLocation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="@color/accent"
                android:maxLines="1"
                android:ellipsize="end"/>

            <TextView
                android:id="@+id/tvLogNotes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="@color/textSecondary"
                android:maxLines="1"
                android:ellipsize="end"
                android:visibility="gone"/>

        </LinearLayout>

        <!-- Right: edit icon + map chip -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:layout_marginStart="10dp">

            <TextView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:text="✎"
                android:textSize="16sp"
                android:textColor="@color/textHint"
                android:gravity="center"
                android:layout_marginBottom="6dp"/>

            <Button
                android:id="@+id/btnViewOnMap"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="64dp"
                android:layout_height="28dp"
                android:text="Map"
                android:textSize="10sp"
                android:textColor="@color/accent"
                app:strokeColor="@color/accent"
                app:cornerRadius="14dp"
                android:visibility="gone"
                android:paddingStart="0dp"
                android:paddingEnd="0dp"/>

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>