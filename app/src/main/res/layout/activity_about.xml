<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/background"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/background"
            app:titleTextColor="@color/textPrimary"
            app:title="Our Story"/>

    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:overScrollMode="never"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Hero banner -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="200dp">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@color/primary"/>

                <View
                    android:layout_width="180dp"
                    android:layout_height="180dp"
                    android:layout_gravity="end|bottom"
                    android:layout_marginEnd="-40dp"
                    android:layout_marginBottom="-30dp"
                    android:background="@drawable/blob_blush"
                    android:alpha="0.15"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:paddingStart="32dp"
                    android:paddingEnd="32dp">

                    <!-- Zogal fruit emoji as logo -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🌿"
                        android:textSize="56sp"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Zogal"
                        android:textSize="32sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="zoğal  ·  cornelian cherry"
                        android:textSize="13sp"
                        android:textColor="#88FFFFFF"
                        android:layout_marginTop="4dp"
                        android:letterSpacing="0.06"/>

                </LinearLayout>
            </FrameLayout>

            <!-- Story body -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="28dp"
                android:paddingEnd="28dp"
                android:paddingTop="32dp"
                android:paddingBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ABOUT"
                    android:textSize="10sp"
                    android:letterSpacing="0.25"
                    android:textColor="@color/textHint"
                    android:layout_marginBottom="10dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/about_title"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="@color/textPrimary"
                    android:lineSpacingMultiplier="1.3"
                    android:layout_marginBottom="20dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/about_body"
                    android:textSize="15sp"
                    android:lineSpacingMultiplier="1.75"
                    android:textColor="@color/textSecondary"/>

            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider"
                android:layout_marginStart="28dp"
                android:layout_marginEnd="28dp"
                android:layout_marginTop="16dp"/>

            <!-- What is Cornelian Cherry card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="20dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/accentMuted">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🌿  What is Cornelian Cherry?"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/accent"
                        android:layout_marginBottom="10dp"/>
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Cornelian cherry (Cornus mas) is a small flowering tree native to Southern Europe and Western Asia. It produces tart, deep-red berries that ripen in late summer. Rich in Vitamin C and antioxidants, it has been eaten and used medicinally for thousands of years across the Caucasus, Turkey, and the Balkans. In Azerbaijan it is called Zoğal — and it is found growing wild in Seattle&#39;s parks and neighbourhoods."
                        android:textSize="13sp"
                        android:lineSpacingMultiplier="1.65"
                        android:textColor="@color/textPrimary"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- How to identify card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/mossGreen">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔍  How to identify it in Seattle"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary"
                        android:layout_marginBottom="10dp"/>
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Look for a multi-stemmed shrub or small tree (3–8m) with oval leaves and peeling grey-brown bark. In early spring it blooms yellow before the leaves appear — one of the earliest bloomers. Fruits ripen to deep red in August–September. The berries are oblong, shiny, and taste like a tart cherry crossed with a cranberry."
                        android:textSize="13sp"
                        android:lineSpacingMultiplier="1.65"
                        android:textColor="@color/primary"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Forager's note -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="28dp"
                android:paddingEnd="28dp"
                android:paddingBottom="56dp"
                android:gravity="center_horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🌿"
                    android:textSize="28sp"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Always leave enough for the birds."
                    android:textSize="14sp"
                    android:textStyle="italic"
                    android:textColor="@color/textHint"
                    android:gravity="center"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Made with love in Seattle, WA"
                    android:textSize="12sp"
                    android:textColor="@color/textHint"
                    android:layout_marginTop="6dp"
                    android:gravity="center"/>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
