<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/background"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/background"
            app:titleTextColor="@color/textPrimary"
            app:title="New Spot"/>

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="false"
        android:nestedScrollingEnabled="true"
        android:overScrollMode="ifContentScrolls"
        android:paddingBottom="32dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- Subtle background blob TL -->
            <View
                android:layout_width="160dp"
                android:layout_height="160dp"
                android:layout_gravity="top|end"
                android:layout_marginEnd="-30dp"
                android:background="@drawable/blob_sage"
                android:alpha="0.35"/>

            <!-- Content -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="22dp"
                android:paddingEnd="22dp"
                android:paddingTop="8dp"
                android:paddingBottom="56dp">

                <!-- Section heading -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tree details"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:textColor="@color/textPrimary"
                    android:layout_marginBottom="22dp"/>

                <!-- ── Row: Tree Name ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/row_bg"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp"
                    android:layout_marginBottom="10dp">

                    <TextView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:text="🌳"
                        android:textSize="18sp"
                        android:gravity="center"
                        android:layout_marginEnd="12dp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Spot name"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="@color/textPrimary"/>

                        <EditText
                            android:id="@+id/editTextTreeName"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textCapWords"
                            android:textColor="@color/textPrimary"
                            android:textSize="14sp"
                            android:hint="e.g. Wild apple by the creek"
                            android:textColorHint="@color/textHint"
                            android:background="@android:color/transparent"
                            android:paddingTop="4dp"
                            android:paddingBottom="0dp"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- ── Row: Tree Type (spinner) ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/row_bg"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp"
                    android:layout_marginBottom="10dp">

                    <TextView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:text="🍎"
                        android:textSize="18sp"
                        android:gravity="center"
                        android:layout_marginEnd="12dp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tree type"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="@color/textPrimary"/>

                        <Spinner
                            android:id="@+id/spinnerTreeType"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/textPrimary"
                            android:background="@android:color/transparent"
                            android:paddingTop="4dp"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- ── Row: Season ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/row_bg"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp"
                    android:layout_marginBottom="10dp">

                    <TextView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:text="🍂"
                        android:textSize="18sp"
                        android:gravity="center"
                        android:layout_marginEnd="12dp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Best harvest season"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="@color/textPrimary"/>

                        <Spinner
                            android:id="@+id/spinnerSeason"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@android:color/transparent"
                            android:paddingTop="4dp"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- ── Row: Location ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/row_bg"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp"
                    android:layout_marginBottom="10dp">

                    <TextView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:text="📍"
                        android:textSize="18sp"
                        android:gravity="center"
                        android:layout_marginEnd="12dp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Location"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="@color/textPrimary"/>

                        <EditText
                            android:id="@+id/editTextLocation"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/textPrimary"
                            android:textSize="14sp"
                            android:hint="e.g. Volunteer Park, Seattle"
                            android:textColorHint="@color/textHint"
                            android:background="@android:color/transparent"
                            android:paddingTop="4dp"
                            android:paddingBottom="0dp"/>

                        <TextView
                            android:id="@+id/tvCoordinates"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="11sp"
                            android:textColor="@color/accent"
                            android:visibility="gone"
                            android:layout_marginTop="3dp"/>

                    </LinearLayout>

                    <Button
                        android:id="@+id/buttonGetLocation"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="GPS"
                        android:textSize="11sp"
                        android:textColor="@color/leafGreen"
                        app:strokeColor="@color/leafGreen"
                        app:cornerRadius="10dp"
                        android:layout_marginStart="10dp"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"/>

                </LinearLayout>

                <!-- ── Row: Notes ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/row_bg"
                    android:orientation="horizontal"
                    android:gravity="top"
                    android:padding="16dp"
                    android:layout_marginBottom="10dp">

                    <TextView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:text="✏️"
                        android:textSize="16sp"
                        android:gravity="center"
                        android:layout_marginEnd="12dp"
                        android:layout_marginTop="2dp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Notes"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="@color/textPrimary"/>

                        <EditText
                            android:id="@+id/editTextNotes"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textMultiLine"
                            android:minLines="3"
                            android:gravity="top"
                            android:textColor="@color/textPrimary"
                            android:textSize="14sp"
                            android:hint="Wild apples near the path, full of fruit in September…"
                            android:textColorHint="@color/textHint"
                            android:background="@android:color/transparent"
                            android:paddingTop="4dp"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- ── Row: Add Photo ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/row_bg"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp"
                    android:layout_marginBottom="10dp">

                    <TextView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:text="📷"
                        android:textSize="18sp"
                        android:gravity="center"
                        android:layout_marginEnd="12dp"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Add photo"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/textPrimary"/>

                    <Button
                        android:id="@+id/buttonSelectImage"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="Gallery"
                        android:textSize="11sp"
                        android:textColor="@color/textSecondary"
                        app:strokeColor="@color/border"
                        app:cornerRadius="10dp"
                        android:layout_marginEnd="6dp"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"/>

                    <Button
                        android:id="@+id/buttonTakePhoto"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="Camera"
                        android:textSize="11sp"
                        android:textColor="@color/textOnDark"
                        android:backgroundTint="@color/primary"
                        app:cornerRadius="10dp"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"/>

                </LinearLayout>

                <!-- Photo preview -->
                <ImageView
                    android:id="@+id/imageViewPreview"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:scaleType="centerCrop"
                    android:visibility="gone"
                    android:layout_marginBottom="16dp"
                    android:background="@color/surfaceVariant"
                    android:contentDescription="Tree photo"
                    android:clipToOutline="true"/>

                <!-- ── Save button — circular, centred ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:layout_marginTop="28dp">

                    <Button
                        android:id="@+id/buttonSaveLog"
                        android:layout_width="160dp"
                        android:layout_height="160dp"
                        android:text="SAVE&#10;TREE"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/textOnDark"
                        android:backgroundTint="@color/primary"
                        app:cornerRadius="80dp"/>

                </LinearLayout>

            </LinearLayout>
        </FrameLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
