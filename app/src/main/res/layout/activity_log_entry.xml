<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/background"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/background"
            app:titleTextColor="@color/textPrimary"
            app:title=""/>

    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:overScrollMode="never"
        android:fillViewport="true"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- Background blobs -->
            <View
                android:layout_width="180dp"
                android:layout_height="180dp"
                android:layout_gravity="top|end"
                android:layout_marginEnd="-40dp"
                android:background="@drawable/blob_sage"
                android:alpha="0.45"/>

            <View
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_gravity="bottom|start"
                android:layout_marginStart="-20dp"
                android:layout_marginBottom="100dp"
                android:background="@drawable/blob_blush"
                android:alpha="0.35"/>

            <!-- Content -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingTop="4dp"
                android:paddingBottom="48dp">

                <!-- Big heading like reference -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ADD A TREE"
                    android:textSize="30sp"
                    android:textStyle="bold"
                    android:textColor="@color/textPrimary"
                    android:layout_marginBottom="28dp"/>

                <!-- Row 1: Tree Name -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/row_bg"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp"
                    android:layout_marginBottom="10dp">

                    <TextView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:text="🌳"
                        android:textSize="18sp"
                        android:gravity="center"
                        android:layout_marginEnd="12dp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tree Type"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="@color/textPrimary"/>

                        <EditText
                            android:id="@+id/editTextTreeName"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textCapWords"
                            android:textColor="@color/textPrimary"
                            android:textSize="13sp"
                            android:hint="e.g. Wild Apple, Cornelian Cherry"
                            android:textColorHint="@color/textHint"
                            android:background="@android:color/transparent"
                            android:paddingTop="4dp"
                            android:paddingBottom="0dp"/>

                    </LinearLayout>
                </LinearLayout>

                <!-- Row 2: Location -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/row_bg"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp"
                    android:layout_marginBottom="10dp">

                    <TextView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:text="📍"
                        android:textSize="18sp"
                        android:gravity="center"
                        android:layout_marginEnd="12dp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Location"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="@color/textPrimary"/>

                        <EditText
                            android:id="@+id/editTextLocation"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/textPrimary"
                            android:textSize="13sp"
                            android:hint="e.g. Seattle, WA"
                            android:textColorHint="@color/textHint"
                            android:background="@android:color/transparent"
                            android:paddingTop="4dp"
                            android:paddingBottom="0dp"/>

                        <TextView
                            android:id="@+id/tvCoordinates"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="11sp"
                            android:textColor="@color/accent"
                            android:visibility="gone"
                            android:layout_marginTop="2dp"/>

                    </LinearLayout>

                    <Button
                        android:id="@+id/buttonGetLocation"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="34dp"
                        android:text="GPS"
                        android:textSize="11sp"
                        android:textColor="@color/accent"
                        app:strokeColor="@color/accent"
                        app:cornerRadius="10dp"
                        android:layout_marginStart="10dp"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"/>

                </LinearLayout>

                <!-- Row 3: Description -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/row_bg"
                    android:orientation="horizontal"
                    android:gravity="top"
                    android:padding="16dp"
                    android:layout_marginBottom="10dp">

                    <TextView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:text="☰"
                        android:textSize="16sp"
                        android:textColor="@color/textSecondary"
                        android:gravity="center"
                        android:layout_marginEnd="12dp"
                        android:layout_marginTop="2dp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Description"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="@color/textPrimary"/>

                        <EditText
                            android:id="@+id/editTextNotes"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textMultiLine"
                            android:minLines="2"
                            android:gravity="top"
                            android:textColor="@color/textPrimary"
                            android:textSize="13sp"
                            android:hint="Wild apples near path, abundant in fall..."
                            android:textColorHint="@color/textHint"
                            android:background="@android:color/transparent"
                            android:paddingTop="4dp"/>

                    </LinearLayout>
                </LinearLayout>

                <!-- Row 4: Add Photo -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/row_bg"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp"
                    android:layout_marginBottom="10dp">

                    <TextView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:text="📷"
                        android:textSize="18sp"
                        android:gravity="center"
                        android:layout_marginEnd="12dp"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Add Photo"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/textPrimary"/>

                    <Button
                        android:id="@+id/buttonSelectImage"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="34dp"
                        android:text="Gallery"
                        android:textSize="11sp"
                        android:textColor="@color/textPrimary"
                        app:strokeColor="@color/border"
                        app:cornerRadius="10dp"
                        android:layout_marginEnd="6dp"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"/>

                    <Button
                        android:id="@+id/buttonTakePhoto"
                        android:layout_width="wrap_content"
                        android:layout_height="34dp"
                        android:text="UPLOAD"
                        android:textSize="11sp"
                        android:textColor="@color/textOnDark"
                        android:backgroundTint="@color/primary"
                        app:cornerRadius="10dp"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"/>

                </LinearLayout>

                <!-- Photo preview -->
                <ImageView
                    android:id="@+id/imageViewPreview"
                    android:layout_width="match_parent"
                    android:layout_height="180dp"
                    android:scaleType="centerCrop"
                    android:visibility="gone"
                    android:layout_marginBottom="16dp"
                    android:background="@color/surfaceVariant"
                    android:contentDescription="Photo preview"/>

                <!-- Big round Save button -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:layout_marginTop="24dp">

                    <Button
                        android:id="@+id/buttonSaveLog"
                        android:layout_width="150dp"
                        android:layout_height="150dp"
                        android:text="SAVE&#10;TREE"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/textOnDark"
                        android:backgroundTint="@color/primary"
                        app:cornerRadius="75dp"/>

                </LinearLayout>

            </LinearLayout>
        </FrameLayout>
    </ScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>