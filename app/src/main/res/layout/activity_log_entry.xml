<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/background"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/background"
            app:titleTextColor="@color/textPrimary"
            app:title=""/>

    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:overScrollMode="never"
        android:fillViewport="true"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- Organic blobs in background -->
            <View
                android:layout_width="160dp"
                android:layout_height="160dp"
                android:layout_gravity="top|end"
                android:layout_marginTop="20dp"
                android:background="@drawable/blob_sage"
                android:alpha="0.5"/>

            <View
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:layout_gravity="bottom|start"
                android:layout_marginStart="20dp"
                android:layout_marginBottom="80dp"
                android:background="@drawable/blob_blush"
                android:alpha="0.4"/>

            <!-- Main content -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="28dp"
                android:paddingEnd="28dp"
                android:paddingTop="8dp"
                android:paddingBottom="40dp">

                <!-- Big heading like reference -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ADD A TREE"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:textColor="@color/textPrimary"
                    android:layout_marginBottom="32dp"/>

                <!-- Row: Tree Name -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="28dp"
                        android:layout_height="wrap_content"
                        android:text="🌳"
                        android:textSize="20sp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tree / Spot Name"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="@color/textPrimary"/>

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/editTextTreeName"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textCapWords"
                            android:textColor="@color/textPrimary"
                            android:textSize="14sp"
                            android:hint="e.g. Wild Apple Tree"
                            android:background="@android:color/transparent"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp"/>

                    </LinearLayout>
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider"
                    android:layout_marginBottom="16dp"/>

                <!-- Row: Location -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="28dp"
                        android:layout_height="wrap_content"
                        android:text="📍"
                        android:textSize="20sp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Location"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="@color/textPrimary"/>

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/editTextLocation"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/textPrimary"
                            android:textSize="14sp"
                            android:hint="e.g. Seattle, WA"
                            android:background="@android:color/transparent"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp"/>

                        <TextView
                            android:id="@+id/tvCoordinates"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="11sp"
                            android:textColor="@color/accent"
                            android:visibility="gone"/>

                    </LinearLayout>

                    <Button
                        android:id="@+id/buttonGetLocation"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="GPS"
                        android:textSize="11sp"
                        android:textColor="@color/textPrimary"
                        app:strokeColor="@color/border"
                        app:cornerRadius="10dp"
                        android:layout_marginStart="8dp"/>

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider"
                    android:layout_marginBottom="16dp"/>

                <!-- Row: Description / Notes -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="top"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="28dp"
                        android:layout_height="wrap_content"
                        android:text="☰"
                        android:textSize="20sp"
                        android:textColor="@color/textSecondary"
                        android:layout_marginTop="4dp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Description"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="@color/textPrimary"/>

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/editTextNotes"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textMultiLine"
                            android:minLines="2"
                            android:gravity="top"
                            android:textColor="@color/textPrimary"
                            android:textSize="14sp"
                            android:hint="Wild apples near path..."
                            android:background="@android:color/transparent"
                            android:paddingTop="4dp"/>

                    </LinearLayout>
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider"
                    android:layout_marginBottom="16dp"/>

                <!-- Row: Add Photo -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="28dp"
                        android:layout_height="wrap_content"
                        android:text="📷"
                        android:textSize="20sp"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Add Photo"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/textPrimary"
                        android:layout_marginStart="12dp"/>

                    <Button
                        android:id="@+id/buttonSelectImage"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="Gallery"
                        android:textSize="11sp"
                        android:textColor="@color/textPrimary"
                        app:strokeColor="@color/border"
                        app:cornerRadius="10dp"
                        android:layout_marginEnd="6dp"/>

                    <Button
                        android:id="@+id/buttonTakePhoto"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="Camera"
                        android:textSize="11sp"
                        android:textColor="@color/textPrimary"
                        app:strokeColor="@color/border"
                        app:cornerRadius="10dp"/>

                </LinearLayout>

                <!-- Photo preview -->
                <ImageView
                    android:id="@+id/imageViewPreview"
                    android:layout_width="match_parent"
                    android:layout_height="180dp"
                    android:scaleType="centerCrop"
                    android:visibility="gone"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="16dp"
                    android:background="@color/surfaceVariant"
                    android:contentDescription="Photo preview"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="32dp"/>

            
                <!-- Big round Save button matching reference -->
                <Button
                    android:id="@+id/buttonSaveLog"
                    android:layout_width="160dp"
                    android:layout_height="160dp"
                    android:layout_gravity="center_horizontal"
                    android:text="SAVE&#10;TREE"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/textOnDark"
                    android:backgroundTint="@color/primary"
                    app:cornerRadius="80dp"/>

            </LinearLayout>
        </FrameLayout>
    </ScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>