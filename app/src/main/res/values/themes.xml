<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.ForagingApp" parent="Theme.Material3.Light.NoActionBar">
        <item name="android:statusBarColor">@color/background</item>
        <item name="android:navigationBarColor">@color/background</item>
        <item name="android:windowBackground">@color/background</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="colorPrimary">@color/primary</item>
        <item name="colorOnPrimary">@color/textOnDark</item>
        <item name="colorSurface">@color/surface</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <style name="Widget.ForagingApp.Button.Primary" parent="Widget.Material3.Button">
        <item name="android:backgroundTint">@color/primary</item>
        <item name="android:textColor">@color/textOnDark</item>
        <item name="android:letterSpacing">0.05</item>
        <item name="cornerRadius">14dp</item>
    </style>

    <style name="Widget.ForagingApp.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:textColor">@color/primary</item>
        <item name="strokeColor">@color/border</item>
        <item name="cornerRadius">14dp</item>
    </style>

    <style name="Widget.ForagingApp.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">14dp</item>
        <item name="boxCornerRadiusTopEnd">14dp</item>
        <item name="boxCornerRadiusBottomStart">14dp</item>
        <item name="boxCornerRadiusBottomEnd">14dp</item>
        <item name="boxStrokeColor">@color/border</item>
        <item name="hintTextColor">@color/textSecondary</item>
    </style>
</resources>